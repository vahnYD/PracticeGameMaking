; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SuccubusShooter"
run/main_scene="res://(1)GameScenes/Forest_level.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=155
config/icon="res://icon.svg"

[autoload]

GlobalScripts="*uid://bhjncy40ath37"
BulletPool="*uid://gkk1gw87oc54"
MinionsPool="*uid://44s8jpq76eg2"
GameLevelManager="*uid://bb802ahx0lntg"
GlobalEnums="*uid://dcua0yinjlrmu"

[display]

window/size/viewport_width=3840
window/size/viewport_height=2160
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="SuccubusShooter"

[editor_plugins]

enabled=PackedStringArray("res://addons/auto_polygon2d_triangulation/plugin.cfg")

[file_customization]

folder_colors={
"res://()Events/": "green",
"res://(1)GameScenes/": "teal",
"res://Bosses/": "red",
"res://Bullets/": "orange",
"res://Components/": "yellow",
"res://Global Scripts/": "blue",
"res://Minions/": "purple"
}

[global_group]

thePlayer=""
Bullet=""
Enemy=""
KillZone=""

